                    </form>
                    <form id="evidenceYoutubeForm" class="evidenceInlineForm">
                        <input type="hidden" name="id" value="<?=$change["id"]?>">
                        <input type="text" name="youtubeID" placeholder="YouTube video ID or URL" class="evidenceTextInput">
