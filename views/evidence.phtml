    <div class="evidenceCard">
        <h2 class="evidenceCardTitle">Verification</h2>

        <?php if ($change["banned"] == 1): ?>
            <p class="evidenceMuted">This run is banned and cannot be verified.</p>
        <?php elseif ($change["pending"] != 1): ?>
            <p class="evidenceVerifiedMsg"><i class="fa fa-check-circle" aria-hidden="true"></i> This run is verified.</p>
        <?php else: ?>
            <?php
                $valid = $view->voteTally["valid"];
                $invalid = $view->voteTally["invalid"];
                $needed = max($view->voteThreshold, $view->voteThreshold * $invalid);
                $progress = $needed > 0 ? min(100, round(($valid / $needed) * 100)) : 0;
            ?>
            <div class="evidenceVoteBar">
                <div class="evidenceVoteBarFill" id="evidenceVoteBarFill" style="width: <?=$progress?>%"></div>
            </div>
            <p class="evidenceVoteTally">
                <span id="evidenceValidCount"><?=$valid?></span> valid /
                <span id="evidenceInvalidCount"><?=$invalid?></span> not valid
                &mdash; needs <?=$view->voteThreshold?>+ valid votes (and at least <?=$view->voteThreshold?>&times; as many valid as not-valid) to auto-verify.
            </p>

            <div class="evidenceActionRow">
                <?php if ($view->isAdmin): ?>
                    <button id="evidenceAdminVerify" class="evidenceButton admin">Verify run (admin)</button>
                <?php endif; ?>

                <?php if (!isset(SteamSignIn::$loggedInUser)): ?>
                    <a href="/login" class="evidenceButton">Sign in through Steam to vote</a>
                <?php elseif ($view->isOwner): ?>
                    <span class="evidenceMuted">You cannot vote on your own run.</span>
                <?php else: ?>
                    <button id="evidenceVoteValid" class="evidenceButton valid<?php if ($view->userVote === 1): ?> active<?php endif; ?>" data-vote="1"><i class="fa fa-check" aria-hidden="true"></i> Valid</button>
                    <button id="evidenceVoteInvalid" class="evidenceButton invalid<?php if ($view->userVote === 0): ?> active<?php endif; ?>" data-vote="0"><i class="fa fa-times" aria-hidden="true"></i> Not valid</button>
                <?php endif; ?>
            </div>
        <?php endif; ?>
    </div>
</div>

<script>
    $(document).ready(function() {
        $("#evidenceDemoForm").on("submit", function(event) {
            event.preventDefault();
            var $btn = $(this).find("button");
            $btn.prop("disabled", true).text("Uploading...");
            $.ajax({
                url: "/uploadDemo",
                data: new FormData(this),
                type: "POST",
                cache: false,
                contentType: false,
                processData: false,
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceYoutubeForm").on("submit", function(event) {
            event.preventDefault();
            var $form = $(this);
            var $btn = $form.find("button");
            $btn.prop("disabled", true).text("Saving...");
            $.ajax({
                url: "/setYoutubeID",
                data: {
                    id: $form.find("[name=id]").val(),
                    youtubeID: $form.find("[name=youtubeID]").val()
                },
                type: "POST",
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceAdminVerify").on("click", function() {
            var $btn = $(this);
            $btn.prop("disabled", true).text("Verifying...");
            $.ajax({
                url: "/verifyScore",
                data: { id: <?=$change["id"]?> },
                type: "POST",
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceVoteValid, #evidenceVoteInvalid").on("click", function() {
            var $button = $(this);
            $("#evidenceVoteValid, #evidenceVoteInvalid").prop("disabled", true);
            $.ajax({
                url: "/voteScore",
                data: { id: <?=$change["id"]?>, vote: $button.data("vote") },
                type: "POST",
                dataType: "json",
                success: function(data) {
                    $("#evidenceVoteValid, #evidenceVoteInvalid").prop("disabled", false);
                    if (data.error) {
                        alert(data.error);
                        return;
                    }
                    if (data.pending == 0) {
                        window.location.reload();
                        return;
                    }
                    $("#evidenceValidCount").text(data.tally.valid);
                    $("#evidenceInvalidCount").text(data.tally.invalid);
                    $("#evidenceVoteValid, #evidenceVoteInvalid").removeClass("active");
                    $button.addClass("active");

                    var needed = Math.max(<?=$view->voteThreshold?>, <?=$view->voteThreshold?> * data.tally.invalid);
                    var progress = needed > 0 ? Math.min(100, Math.round((data.tally.valid / needed) * 100)) : 0;
                    $("#evidenceVoteBarFill").css("width", progress + "%");
                },
                error: function() {
                    $("#evidenceVoteValid, #evidenceVoteInvalid").prop("disabled", false);
                }
            });
        });
    });
</script>
