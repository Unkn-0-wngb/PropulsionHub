<?php $change = $view->evidenceChange; ?>

<div id="evidence">
    <h1 class="largeTitle">Evidence</h1>

    <div class="container">
        <p>
            <a href="/profile/<?=$change["profile_number"]?>"><?=$change["player_name"]?></a>
            on <a href="/chamber/<?=$change["mapid"]?>"><?=$change["chamberName"]?></a>
            (<a href="/aggregated/chapter/<?=$change["chapterId"]?>"><?=$GLOBALS["mapInfo"]["chapters"][$change["chapterId"]]["chapterName"]?></a>)
            &mdash; <?=Leaderboard::convertToTime($change["score"])?>
        </p>
        <p id="evidenceStatus">
            <?php if ($change["banned"] == 1): ?>
                Status: <strong>Banned</strong>
            <?php elseif ($change["pending"] == 1): ?>
                Status: <strong>Pending &mdash; evidence required</strong>
            <?php else: ?>
                Status: <strong>Verified</strong>
            <?php endif; ?>
        </p>
    </div>

    <h1 class="title">Submitted evidence</h1>
    <div class="container">
        <p id="evidenceDemoLink">
            <?php if ($change["hasDemo"] == 1): ?>
                Demo: <a href="/getDemo?id=<?=$change["id"]?>">Download .dem</a>
            <?php else: ?>
                No demo file has been provided for this run.
            <?php endif; ?>
        </p>
        <p id="evidenceYoutubeLink">
            <?php if ($change["youtubeID"] != NULL): ?>
                YouTube: <a href="#" onclick="embedOnBody('<?=$change["youtubeID"]?>', '<?=$change["chamberName"]?> - <?=Leaderboard::convertToTime($change["score"])?> - <?=Util::escapeQuotesHTML($change["player_name"])?>'); return false;">Watch</a>
            <?php else: ?>
                No YouTube link has been provided for this run.
            <?php endif; ?>
        </p>

        <?php if ($view->isOwner): ?>
            <h2>Add evidence</h2>
            <p>This is your run &mdash; you can attach a demo file and/or a YouTube link below.</p>

            <form id="evidenceDemoForm">
                <input type="hidden" name="id" value="<?=$change["id"]?>">
                <input type="file" name="demoFile" accept=".dem">
                <input type="submit" value="Upload demo" class="button">
            </form>

            <form id="evidenceYoutubeForm">
                <input type="hidden" name="id" value="<?=$change["id"]?>">
                <input type="text" name="youtubeID" placeholder="YouTube video ID or URL">
                <input type="submit" value="Save YouTube link" class="button">
            </form>
        <?php endif; ?>
    </div>

    <h1 class="title">Verification</h1>
    <div class="container">
        <?php if ($change["banned"] == 1): ?>
            <p>This run is banned and cannot be verified.</p>
        <?php elseif ($change["pending"] != 1): ?>
            <p>This run is already verified.</p>
        <?php else: ?>
            <?php if ($view->isAdmin): ?>
                <p>
                    <button id="evidenceAdminVerify" class="button">Verify run (admin)</button>
                </p>
            <?php endif; ?>

            <p id="evidenceVoteTally">
                <span id="evidenceValidCount"><?=$view->voteTally["valid"]?></span> valid /
                <span id="evidenceInvalidCount"><?=$view->voteTally["invalid"]?></span> not valid
                &mdash; needs at least <?=$view->voteThreshold?> valid votes, and at least <?=$view->voteThreshold?>&times; as many valid votes as not-valid votes, to auto-verify.
            </p>

            <?php if (!isset(SteamSignIn::$loggedInUser)): ?>
                <p><a href="/login">Sign in through Steam</a> to vote on this run.</p>
            <?php elseif ($view->isOwner): ?>
                <p>You cannot vote on your own run.</p>
            <?php else: ?>
                <p>
                    <button id="evidenceVoteValid" class="button<?php if ($view->userVote === 1): ?> active<?php endif; ?>" data-vote="1">Vote Valid</button>
                    <button id="evidenceVoteInvalid" class="button<?php if ($view->userVote === 0): ?> active<?php endif; ?>" data-vote="0">Vote Not Valid</button>
                </p>
            <?php endif; ?>
        <?php endif; ?>
    </div>
</div>

<script>
    $(document).ready(function() {
        $("#evidenceDemoForm").on("submit", function(event) {
            event.preventDefault();
            $.ajax({
                url: "/uploadDemo",
                data: new FormData(this),
                type: "POST",
                cache: false,
                contentType: false,
                processData: false,
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceYoutubeForm").on("submit", function(event) {
            event.preventDefault();
            var $form = $(this);
            $.ajax({
                url: "/setYoutubeID",
                data: {
                    id: $form.find("[name=id]").val(),
                    youtubeID: $form.find("[name=youtubeID]").val()
                },
                type: "POST",
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceAdminVerify").on("click", function() {
            $.ajax({
                url: "/verifyScore",
                data: { id: <?=$change["id"]?> },
                type: "POST",
                success: function() {
                    window.location.reload();
                }
            });
        });

        $("#evidenceVoteValid, #evidenceVoteInvalid").on("click", function() {
            var $button = $(this);
            $.ajax({
                url: "/voteScore",
                data: { id: <?=$change["id"]?>, vote: $button.data("vote") },
                type: "POST",
                dataType: "json",
                success: function(data) {
                    if (data.error) {
                        alert(data.error);
                        return;
                    }
                    if (data.pending == 0) {
                        window.location.reload();
                        return;
                    }
                    $("#evidenceValidCount").text(data.tally.valid);
                    $("#evidenceInvalidCount").text(data.tally.invalid);
                    $("#evidenceVoteValid, #evidenceVoteInvalid").removeClass("active");
                    $button.addClass("active");
                }
            });
        });
    });
</script>
