        <script>
            function getCookie(name) {
                const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                return match ? match[2] : null;
            }
            function setCookie(name, value) {
                const d = new Date();
                d.setTime(d.getTime() + (10 * 365 * 24 * 60 * 60 * 1000)); // 10 years
                document.cookie = name + '=' + value + '; path=/; expires=' + d.toGMTString();
            }

            // Light is the default; dark is opt-in and persisted via cookie
            // (not localStorage) so it's available to server-rendered pages too.
            getCookie('color-theme') === 'dark' && document.documentElement.classList.add('dark');

            function toggleTheme() {
                if (getCookie('color-theme') === 'dark') {
                    setCookie('color-theme', 'light');
                    document.documentElement.classList.remove('dark');
                } else {
                    setCookie('color-theme', 'dark');
                    document.documentElement.classList.add('dark');
                }

                if (location.pathname.startsWith('/changelog') || location.pathname.startsWith('/profile/')) {
                    $(".rank, .preRank, .postRank").each(function() {
                        !this.firstElementChild && drawRank($(this));
                    });
                }
            }
        </script>
